@model List<poo.Models.Flower>

@{
    ViewData["Title"] = "Flores";
}

<div class="container mt-4">
    <h2 class="mb-4 text-center">Lista de Flores</h2>

    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Tipo</th>
                <th>Espécie</th>
                <th>Cor</th>
                <th>Aroma</th>
                <th>Tamanho (cm)</th>
                <th>Valor (R$)</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var flower in Model)
            {
                <tr>
                    <td>@flower.FlowerId</td>
                    <td>@flower.Tipo</td>
                    <td>@flower.Especie</td>
                    <td>@flower.Cor</td>
                    <td>@flower.Aroma</td>
                    <td>@flower.Tamanho</td>
                    <td>@flower.Valor.ToString("F2")</td>
                </tr>
            }
        </tbody>
    </table>
</div>